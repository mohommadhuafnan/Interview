{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend/app/main.py",
      "routePrefix": "/_/backend",
      "framework": "fastapi",
      "includeFiles": ["ai_models/**"],
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
